# Copy to .env and fill in real values. .env is gitignored — never commit it.

# Supabase (PostgreSQL) connection string, asyncpg-compatible.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/cashflow

# Telegram bot token
BOT_TOKEN=000000000:AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA

# Base URL the bot uses to reach this backend.
BACKEND_BASE_URL=http://localhost:8000

# Shared secret the bot sends as X-Internal-Token on every request;
# backend rejects requests without a valid match.
# python3 -c "import secrets; print(secrets.token_urlsafe(32))"
# or -> openssl rand -hex 32
INTERNAL_TOKEN=change-me-to-a-random-secret

# Comma-separated Telegram user ids allowed to use the bot.
ALLOWED_TG_IDS=123456789,987654321
